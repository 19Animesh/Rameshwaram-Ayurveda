# Environment variables required for Production Deployment on Vercel

# 1. DATABASE
DATABASE_URL="postgresql://<username>:<password>@<neon-host-url>/<db-name>?sslmode=require"

# 2. AUTHENTICATION (Can be any random secure string)
JWT_SECRET="generate_a_random_secure_long_string_here"

# 3. CLOUDINARY (If using external images, Optional but recommended)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# 4. EMAIL SERVER (For sending OTPs)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_EMAIL="your-email@gmail.com"
SMTP_PASSWORD="your-google-app-password"
SMTP_FROM_NAME="Rameshwaram Ayurveda"

# 5. PAYMENT GATEWAY (Razorpay)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_your_key_here"
RAZORPAY_KEY_SECRET="your_razorpay_secret_here"
